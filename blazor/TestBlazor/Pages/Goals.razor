@page "/goals"
@inject IJSRuntime JSRuntime

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goals-form">
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input type="text" class="form-control" id="goalTitle" @bind="currentTitle" placeholder="Enter your goal" maxlength="200" />
    </div>

    <div class="mb-3">
        <label for="goalDate" class="form-label">Target Date (Optional)</label>
        <input type="date" class="form-control" id="goalDate" @bind="currentTargetDate" />
    </div>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="alert alert-warning" role="alert">
            @validationMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list mt-4">
    @if (goals.Count == 0)
    {
        <p class="text-muted"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        <h3>Your Goals</h3>
        <ul class="list-unstyled">
            @foreach (var goal in goals)
            {
                <li class="goal-item @(goal.IsCompleted ? "completed" : "")">
                    <div class="goal-content">
                        <div class="goal-header">
                            <span class="goal-title">@goal.Title</span>
                            @if (goal.TargetDate.HasValue)
                            {
                                <span class="goal-date">@goal.TargetDate.Value.ToShortDateString()</span>
                            }
                        </div>
                        <div class="goal-actions">
                            <button class="btn btn-sm btn-outline-success"
                                    @onclick="() => ToggleGoal(goal.Id)"
                                    aria-label="@(goal.IsCompleted ? "Mark goal as incomplete" : "Mark goal as complete")">
                                @(goal.IsCompleted ? "Undo" : "Complete")
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private const string StorageKey = "goals-data";
    private const int MaxTitleLength = 200;

    private List<GoalItem> goals = new List<GoalItem>();
    private string currentTitle = string.Empty;
    private DateTime? currentTargetDate;
    private string? validationMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadGoalsAsync();
    }

    private async Task LoadGoalsAsync()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                goals = System.Text.Json.JsonSerializer.Deserialize<List<GoalItem>>(json) ?? new List<GoalItem>();
            }
        }
        catch
        {
            // If loading fails, start with empty list
            goals = new List<GoalItem>();
        }
    }

    private async Task SaveGoalsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(goals);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
            // Silently fail - data will still work in current session
        }
    }

    private async Task AddGoal()
    {
        // Trim and validate the title
        var trimmedTitle = currentTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrEmpty(trimmedTitle))
        {
            validationMessage = "Please enter a goal title.";
            successMessage = null;
            return;
        }

        if (trimmedTitle.Length > MaxTitleLength)
        {
            validationMessage = $"Goal title must be {MaxTitleLength} characters or less.";
            successMessage = null;
            return;
        }

        // Create and add the new goal
        var newGoal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = currentTargetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);
        await SaveGoalsAsync();

        // Clear the form and show success message
        currentTitle = string.Empty;
        currentTargetDate = null;
        validationMessage = null;
        successMessage = "Goal added successfully!";

        // Clear success message after a delay
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            successMessage = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task ToggleGoal(Guid id)
    {
        var goal = GetGoal(id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
            await SaveGoalsAsync();
        }
    }

    private async Task DeleteGoal(Guid id)
    {
        var goal = GetGoal(id);
        if (goal != null)
        {
            goals.Remove(goal);
            await SaveGoalsAsync();
        }
    }

    private GoalItem? GetGoal(Guid id)
    {
        return goals.FirstOrDefault(g => g.Id == id);
    }

    private class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
