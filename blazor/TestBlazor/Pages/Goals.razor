@page "/goals"
@inject IJSRuntime JSRuntime

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <h3>Add New Goal</h3>

    @if (showValidationMessage)
    {
        <div class="validation-message">Goal title is required</div>
    }

    <div class="form-group">
        <label for="goalTitle">Goal Title:</label>
        <input id="goalTitle" class="form-control" @bind="newGoalTitle" @bind:event="oninput" placeholder="Enter goal title" />
    </div>

    <div class="form-group">
        <label for="targetDate">Target Date (optional):</label>
        <input id="targetDate" type="date" class="form-control" @bind="newGoalTargetDate" />
    </div>

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list">
    <h3>Your Goals</h3>

    @if (goals.Count == 0)
    {
        <p class="no-goals">No goals yet. Add one above to get started!</p>
    }
    else
    {
        <div class="goals-section">
            @foreach (var goal in goals.Where(g => !g.IsCompleted))
            {
                <GoalItemComponent
                    Id="@goal.Id"
                    Title="@goal.Title"
                    TargetDate="@goal.TargetDate"
                    IsCompleted="@goal.IsCompleted"
                    OnToggleGoal="@ToggleGoal"
                    OnDeleteGoal="@DeleteGoal" />
            }
        </div>

        @if (goals.Any(g => g.IsCompleted))
        {
            <h4 class="completed-header">Completed</h4>
            <div class="goals-section">
                @foreach (var goal in goals.Where(g => g.IsCompleted))
                {
                    <GoalItemComponent
                        Id="@goal.Id"
                        Title="@goal.Title"
                        TargetDate="@goal.TargetDate"
                        IsCompleted="@goal.IsCompleted"
                        OnToggleGoal="@ToggleGoal"
                        OnDeleteGoal="@DeleteGoal" />
                }
            </div>
        }
    }
</div>

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate = null;
    private bool showValidationMessage = false;
    private const string LocalStorageKey = "blazor_goals";

    protected override async Task OnInitializedAsync()
    {
        await LoadGoals();
    }

    private async Task LoadGoals()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", LocalStorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                goals = System.Text.Json.JsonSerializer.Deserialize<List<Goal>>(json) ?? new List<Goal>();
            }
        }
        catch
        {
            // If localStorage is not available or parsing fails, start with empty list
            goals = new List<Goal>();
        }
    }

    private async Task SaveGoals()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(goals);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, json);
        }
        catch
        {
            // Silently fail if localStorage is not available
        }
    }

    private async Task AddGoal()
    {
        // Trim whitespace and validate
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            showValidationMessage = true;
            return;
        }

        // Create new goal
        var goal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Reset form
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
        showValidationMessage = false;

        // Persist to localStorage
        await SaveGoals();
    }

    private async Task ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
            await SaveGoals();
        }
    }

    private async Task DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
            await SaveGoals();
        }
    }

    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
