@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your goals and mark them as completed.</p>

<div class="goal-form">
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input type="text" class="form-control" id="goalTitle" @bind="newGoalTitle" placeholder="Enter your goal" />
    </div>
    <div class="mb-3">
        <label for="goalDate" class="form-label">Target Date (Optional)</label>
        <input type="date" class="form-control" id="goalDate" @bind="newGoalDate" />
    </div>
    @if (showValidationMessage)
    {
        <div class="alert alert-warning" role="alert">
            Please enter a goal title.
        </div>
    }
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

@if (goals.Count == 0)
{
    <p class="mt-4"><em>No goals yet. Add your first goal above!</em></p>
}
else
{
    <div class="goals-list mt-4">
        <h2>Your Goals</h2>
        @foreach (var goal in goals.OrderBy(g => g.IsCompleted).ThenBy(g => g.TargetDate))
        {
            <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                <div class="goal-content">
                    <div class="goal-header">
                        <button class="btn btn-sm @(goal.IsCompleted ? "btn-outline-secondary" : "btn-outline-success")"
                                @onclick="() => ToggleGoal(goal.Id)"
                                title="@(goal.IsCompleted ? "Mark as incomplete" : "Mark as complete")">
                            @if (goal.IsCompleted)
                            {
                                <span>&#10003;</span>
                            }
                            else
                            {
                                <span>&#9675;</span>
                            }
                        </button>
                        <span class="goal-title">@goal.Title</span>
                    </div>
                    @if (goal.TargetDate.HasValue)
                    {
                        <div class="goal-date">
                            <small>Target: @goal.TargetDate.Value.ToShortDateString()</small>
                        </div>
                    }
                </div>
                <button class="btn btn-sm btn-outline-danger delete-btn"
                        @onclick="() => DeleteGoal(goal.Id)"
                        title="Delete goal">
                    &times;
                </button>
            </div>
        }
    </div>
}

@code {
    private List<GoalItem> goals = new();
    private string newGoalTitle = string.Empty;
    private DateOnly? newGoalDate;
    private bool showValidationMessage = false;

    private void AddGoal()
    {
        // Trim and validate input
        var trimmedTitle = newGoalTitle.Trim();

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            showValidationMessage = true;
            return;
        }

        // Add the new goal
        goals.Add(new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalDate,
            IsCompleted = false
        });

        // Reset form
        newGoalTitle = string.Empty;
        newGoalDate = null;
        showValidationMessage = false;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateOnly? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
