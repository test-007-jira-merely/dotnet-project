@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <h3>Add a new goal</h3>

    <div class="mb-3">
        <label for="goalTitle" class="form-label">Title</label>
        <input type="text" class="form-control" id="goalTitle" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>

    <div class="mb-3">
        <label for="goalDate" class="form-label">Target Date (optional)</label>
        <input type="date" class="form-control" id="goalDate" @bind="newGoalTargetDate" />
    </div>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="alert alert-warning" role="alert">
            @validationMessage
        </div>
    }

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goal-list mt-5">
    <h3>Your Goals</h3>

    @if (goals.Count == 0)
    {
        <p><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        <div class="list-group">
            @foreach (var goal in goals)
            {
                <div class="list-group-item goal-item @(goal.IsCompleted ? "goal-completed" : "")">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@goal.Title</h5>
                            @if (goal.TargetDate.HasValue)
                            {
                                <small class="text-muted">Target: @goal.TargetDate.Value.ToShortDateString()</small>
                            }
                        </div>
                        <div class="btn-group ms-3" role="group">
                            <button class="btn btn-sm @(goal.IsCompleted ? "btn-success" : "btn-outline-success")"
                                    @onclick="() => ToggleGoal(goal.Id)"
                                    title="@(goal.IsCompleted ? "Mark as incomplete" : "Mark as complete")">
                                @(goal.IsCompleted ? "✓" : "○")
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteGoal(goal.Id)"
                                    title="Delete goal">
                                ×
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<GoalItem> goals = new();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Trim and validate title
        var trimmedTitle = newGoalTitle.Trim();

        if (string.IsNullOrEmpty(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Clear validation message
        validationMessage = string.Empty;

        // Create and add new goal
        var goal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Clear input fields
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    public class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
