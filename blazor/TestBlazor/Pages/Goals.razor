@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goals-form">
    <div class="form-row">
        <div class="form-group">
            <label for="goalTitle">Goal Title</label>
            <input id="goalTitle"
                   type="text"
                   class="form-control"
                   @bind="newGoalTitle"
                   @bind:event="oninput"
                   placeholder="Enter goal title" />
        </div>
        <div class="form-group">
            <label for="targetDate">Target Date (optional)</label>
            <input id="targetDate"
                   type="date"
                   class="form-control"
                   @bind="newGoalDate" />
        </div>
        <div class="form-group">
            <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-message">
            @validationMessage
        </div>
    }
</div>

<div class="goals-list">
    @if (goals.Count == 0)
    {
        <p class="no-goals"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        @foreach (var goal in goals)
        {
            <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                <div class="goal-content">
                    <div class="goal-checkbox">
                        <input type="checkbox"
                               id="goal-@goal.Id"
                               checked="@goal.IsCompleted"
                               @onchange="() => ToggleGoal(goal.Id)" />
                    </div>
                    <div class="goal-details">
                        <label for="goal-@goal.Id" class="goal-title">@goal.Title</label>
                        @if (goal.TargetDate.HasValue)
                        {
                            <div class="goal-date">
                                <span class="bi bi-calendar3"></span>
                                Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")
                            </div>
                        }
                    </div>
                </div>
                <div class="goal-actions">
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<GoalItem> goals = new List<GoalItem>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalDate;
    private string? validationMessage;

    private void AddGoal()
    {
        // Clear previous validation message
        validationMessage = null;

        // Trim and validate title
        var title = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(title))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Create and add new goal
        var newGoal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = title,
            TargetDate = newGoalDate,
            IsCompleted = false
        };

        goals.Add(newGoal);

        // Reset form
        newGoalTitle = string.Empty;
        newGoalDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
