@page "/goals"
@inject IJSRuntime JSRuntime

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and mark them as completed.</p>

<div class="goal-form">
    <div class="form-group mb-3">
        <label for="goalTitle" class="form-label">Goal Title (Max 200 characters)</label>
        <input id="goalTitle" class="form-control" @bind="goalTitle" placeholder="Enter your goal" maxlength="200" />
    </div>

    <div class="form-group mb-3">
        <label for="targetDate" class="form-label">Target Date (Optional)</label>
        <input id="targetDate" type="date" class="form-control" @bind="targetDate" />
    </div>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="alert alert-danger" role="alert">
            @validationMessage
        </div>
    }

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list mt-4">
    @if (goals.Count == 0)
    {
        <p class="text-muted"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        <h3>Active Goals</h3>
        <ul class="list-group mb-4">
            @foreach (var goal in activeGoals)
            {
                <GoalItemComponent Goal="goal"
                                   ActionLabel="Complete"
                                   ActionButtonClass="btn-success"
                                   IsCompleted="false"
                                   OnToggleGoal="HandleToggleGoal"
                                   OnDeleteGoal="HandleDeleteGoal" />
            }
        </ul>

        @if (completedGoals.Count > 0)
        {
            <h3>Completed Goals</h3>
            <ul class="list-group">
                @foreach (var goal in completedGoals)
                {
                    <GoalItemComponent Goal="goal"
                                       ActionLabel="Reactivate"
                                       ActionButtonClass="btn-warning"
                                       IsCompleted="true"
                                       OnToggleGoal="HandleToggleGoal"
                                       OnDeleteGoal="HandleDeleteGoal" />
                }
            </ul>
        }
    }
</div>

@code {
    private const string StorageKey = "goalsData";
    private const int MaxTitleLength = 200;

    private List<GoalItem> goals = new();
    private List<GoalItem> activeGoals = new();
    private List<GoalItem> completedGoals = new();
    private string goalTitle = string.Empty;
    private DateTime? targetDate;
    private string? validationMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadGoalsFromStorage();
    }

    private async Task LoadGoalsFromStorage()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                goals = System.Text.Json.JsonSerializer.Deserialize<List<GoalItem>>(json) ?? new();
                UpdateCachedLists();
            }
        }
        catch
        {
            // If localStorage fails, continue with empty list
            goals = new();
        }
    }

    private async Task SaveGoalsToStorage()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(goals);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
            // Silently handle storage errors
        }
    }

    private void UpdateCachedLists()
    {
        activeGoals = goals.Where(g => !g.IsCompleted).ToList();
        completedGoals = goals.Where(g => g.IsCompleted).ToList();
    }

    private async Task AddGoal()
    {
        // Clear previous validation message
        validationMessage = null;

        // Trim and validate the title
        var trimmedTitle = goalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title is required.";
            return;
        }

        // Validate length (sanitization)
        if (trimmedTitle.Length > MaxTitleLength)
        {
            validationMessage = $"Goal title cannot exceed {MaxTitleLength} characters.";
            return;
        }

        // Create and add the new goal
        var newGoal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = targetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);
        UpdateCachedLists();
        await SaveGoalsToStorage();

        // Clear the form inputs
        goalTitle = string.Empty;
        targetDate = null;
    }

    private async Task HandleToggleGoal(Guid id)
    {
        var goal = FindGoal(id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
            UpdateCachedLists();
            await SaveGoalsToStorage();
        }
    }

    private async Task HandleDeleteGoal(Guid id)
    {
        var goal = FindGoal(id);
        if (goal != null)
        {
            goals.Remove(goal);
            UpdateCachedLists();
            await SaveGoalsToStorage();
        }
    }

    // Extract duplicate goal-finding logic (DRY principle)
    private GoalItem? FindGoal(Guid id)
    {
        return goals.FirstOrDefault(g => g.Id == id);
    }

    public class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
