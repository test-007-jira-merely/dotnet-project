@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and mark them as completed.</p>

<div class="goal-form">
    <div class="form-group mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input id="goalTitle" class="form-control" @bind="goalTitle" placeholder="Enter your goal" />
    </div>

    <div class="form-group mb-3">
        <label for="targetDate" class="form-label">Target Date (Optional)</label>
        <input id="targetDate" type="date" class="form-control" @bind="targetDate" />
    </div>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="alert alert-danger" role="alert">
            @validationMessage
        </div>
    }

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list mt-4">
    @if (goals.Count == 0)
    {
        <p class="text-muted"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        <h3>Active Goals</h3>
        <ul class="list-group mb-4">
            @foreach (var goal in ActiveGoals)
            {
                @RenderGoalItem(goal, "Complete", "btn-success")
            }
        </ul>

        @if (CompletedGoals.Any())
        {
            <h3>Completed Goals</h3>
            <ul class="list-group">
                @foreach (var goal in CompletedGoals)
                {
                    @RenderGoalItem(goal, "Reactivate", "btn-warning", isCompleted: true)
                }
            </ul>
        }
    }
</div>

@code {
    private List<GoalItem> goals = new();
    private string goalTitle = string.Empty;
    private DateTime? targetDate;
    private string? validationMessage;

    // Cached filtered lists to avoid repeated LINQ queries during render
    private IEnumerable<GoalItem> ActiveGoals => goals.Where(g => !g.IsCompleted);
    private IEnumerable<GoalItem> CompletedGoals => goals.Where(g => g.IsCompleted);

    // Reusable goal rendering method to follow DRY principle
    private RenderFragment RenderGoalItem(GoalItem goal, string actionLabel, string actionButtonClass, bool isCompleted = false) => builder =>
    {
        builder.OpenElement(0, "li");
        builder.AddAttribute(1, "class", isCompleted ? "list-group-item completed" : "list-group-item");

        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "class", "goal-item");

        // Goal content
        builder.OpenElement(4, "div");
        builder.AddAttribute(5, "class", "goal-content");

        builder.OpenElement(6, "strong");
        builder.AddContent(7, goal.Title);
        builder.CloseElement();

        if (goal.TargetDate.HasValue)
        {
            builder.OpenElement(8, "span");
            builder.AddAttribute(9, "class", "text-muted ms-2");
            builder.OpenElement(10, "small");
            builder.AddContent(11, $"(Target: {goal.TargetDate.Value.ToShortDateString()})");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement(); // goal-content

        // Goal actions
        builder.OpenElement(12, "div");
        builder.AddAttribute(13, "class", "goal-actions");

        builder.OpenElement(14, "button");
        builder.AddAttribute(15, "class", $"btn btn-sm {actionButtonClass}");
        builder.AddAttribute(16, "onclick", EventCallback.Factory.Create(this, () => ToggleGoal(goal.Id)));
        builder.AddContent(17, actionLabel);
        builder.CloseElement();

        builder.OpenElement(18, "button");
        builder.AddAttribute(19, "class", "btn btn-sm btn-danger");
        builder.AddAttribute(20, "onclick", EventCallback.Factory.Create(this, () => DeleteGoal(goal.Id)));
        builder.AddContent(21, "Delete");
        builder.CloseElement();

        builder.CloseElement(); // goal-actions
        builder.CloseElement(); // goal-item
        builder.CloseElement(); // li
    };

    private void AddGoal()
    {
        // Clear previous validation message
        validationMessage = null;

        // Trim and validate the title
        var trimmedTitle = goalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title is required.";
            return;
        }

        // Create and add the new goal
        var newGoal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = targetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);

        // Clear the form inputs
        goalTitle = string.Empty;
        targetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    public class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
