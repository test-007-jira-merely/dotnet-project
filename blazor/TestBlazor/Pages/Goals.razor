@page "/goals"
@using TestBlazor.Models
@using System.Text.Encodings.Web
@using System.Text.Json
@inject IJSRuntime JSRuntime

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <h2>Add a New Goal</h2>
    <div class="form-group mb-3">
        <label for="goalTitle">Goal Title:</label>
        <input
            id="goalTitle"
            type="text"
            class="form-control"
            @bind="newTitle"
            @oninput="ClearValidationError"
            placeholder="Enter your goal..." />
    </div>
    <div class="form-group mb-3">
        <label for="targetDate">Target Date (optional):</label>
        <input
            id="targetDate"
            type="date"
            class="form-control"
            aria-label="Target date for goal"
            @bind="newTargetDate" />
    </div>
    @if (!string.IsNullOrEmpty(validationError))
    {
        <div class="validation-error">
            @validationError
        </div>
    }
    <button class="btn btn-primary" @onclick="async () => await AddGoal()">Add Goal</button>
</div>

<div class="goal-list">
    <h2>My Goals</h2>
    @if (goals.Count == 0)
    {
        <p class="text-muted">No goals yet. Add one above to get started!</p>
    }
    else
    {
        <ul class="list-unstyled">
            @foreach (var goal in goals)
            {
                <li class="goal-item @(goal.IsCompleted ? "completed" : "")">
                    <div class="goal-content">
                        <div class="goal-info">
                            <strong class="goal-title">@((MarkupString)HtmlEncoder.Default.Encode(goal.Title))</strong>
                            @if (goal.TargetDate.HasValue)
                            {
                                <span class="goal-date">Target: @goal.TargetDate.Value.ToShortDateString()</span>
                            }
                        </div>
                        <div class="goal-actions">
                            <button class="btn btn-sm btn-success" @onclick="async () => await ToggleGoal(goal.Id)">
                                @(goal.IsCompleted ? "Reopen" : "Complete")
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="async () => await DeleteGoal(goal.Id)">
                                Delete
                            </button>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private const string LocalStorageKey = "goals";
    private List<GoalItem> goals = new();
    private string newTitle = string.Empty;
    private DateTime? newTargetDate = null;
    private string? validationError = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadGoalsAsync();
    }

    private async Task AddGoal()
    {
        // Trim whitespace from title
        var trimmedTitle = newTitle?.Trim() ?? string.Empty;

        // Validate that title is not empty
        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationError = "Goal title cannot be empty. Please enter a title.";
            return;
        }

        // Create new goal (encoding happens at display time, not storage time)
        var newGoal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newTargetDate,
            IsCompleted = false
        };

        // Add to list
        goals.Add(newGoal);

        // Save to local storage
        await SaveGoalsAsync();

        // Clear form
        newTitle = string.Empty;
        newTargetDate = null;
        validationError = null;
    }

    private async Task ToggleGoal(Guid id)
    {
        var goal = GetGoalById(id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
            await SaveGoalsAsync();
        }
    }

    private async Task DeleteGoal(Guid id)
    {
        var goal = GetGoalById(id);
        if (goal != null)
        {
            goals.Remove(goal);
            await SaveGoalsAsync();
        }
    }

    private GoalItem? GetGoalById(Guid id)
    {
        return goals.FirstOrDefault(g => g.Id == id);
    }

    private void ClearValidationError(ChangeEventArgs e)
    {
        validationError = null;
        newTitle = e.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveGoalsAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(goals);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, json);
        }
        catch (Exception ex)
        {
            // Log localStorage failures for debugging (private browsing, quota exceeded, etc.)
            System.Diagnostics.Debug.WriteLine($"localStorage save error: {ex.Message}");
            Console.Error.WriteLine($"Failed to save goals to localStorage: {ex.Message}");
        }
    }

    private async Task LoadGoalsAsync()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", LocalStorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                goals = JsonSerializer.Deserialize<List<GoalItem>>(json) ?? new List<GoalItem>();
            }
        }
        catch (Exception ex)
        {
            // Log localStorage failures for debugging (private browsing, quota exceeded, corrupted data, etc.)
            System.Diagnostics.Debug.WriteLine($"localStorage load error: {ex.Message}");
            Console.Error.WriteLine($"Failed to load goals from localStorage: {ex.Message}");
            goals = new List<GoalItem>();
        }
    }
}
