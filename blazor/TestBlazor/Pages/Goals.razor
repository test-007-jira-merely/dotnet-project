@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <div class="form-group">
        <label for="goalTitle">Goal Title</label>
        <input type="text" id="goalTitle" class="form-control" @bind="newGoalTitle" placeholder="Enter your goal" />
    </div>
    <div class="form-group">
        <label for="goalTargetDate">Target Date (optional)</label>
        <input type="date" id="goalTargetDate" class="form-control" @bind="newGoalTargetDate" />
    </div>
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-message">@validationMessage</div>
    }
</div>

<div class="goals-list">
    @if (goals.Count == 0)
    {
        <p class="no-goals">No goals yet. Add your first goal above!</p>
    }
    else
    {
        <h2>Active Goals</h2>
        @foreach (var goal in goals.Where(g => !g.IsCompleted))
        {
            <div class="goal-item">
                <div class="goal-content">
                    <div class="goal-header">
                        <span class="goal-title">@goal.Title</span>
                        @if (goal.TargetDate.HasValue)
                        {
                            <span class="goal-date">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</span>
                        }
                    </div>
                </div>
                <div class="goal-actions">
                    <button class="btn btn-sm btn-success" @onclick="() => ToggleGoal(goal.Id)">Complete</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                </div>
            </div>
        }

        @if (goals.Any(g => g.IsCompleted))
        {
            <h2>Completed Goals</h2>
            @foreach (var goal in goals.Where(g => g.IsCompleted))
            {
                <div class="goal-item completed">
                    <div class="goal-content">
                        <div class="goal-header">
                            <span class="goal-title">@goal.Title</span>
                            @if (goal.TargetDate.HasValue)
                            {
                                <span class="goal-date">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</span>
                            }
                        </div>
                    </div>
                    <div class="goal-actions">
                        <button class="btn btn-sm btn-warning" @onclick="() => ToggleGoal(goal.Id)">Undo</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private List<GoalItem> goals = new List<GoalItem>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Trim the input
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        // Validate: prevent empty titles
        if (string.IsNullOrEmpty(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Create and add the new goal
        var goal = new GoalItem
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Clear form and validation message
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
        validationMessage = string.Empty;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    // Internal model for goals
    private class GoalItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
