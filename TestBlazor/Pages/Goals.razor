@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <div class="form-group">
        <label for="goalTitle">Goal Title</label>
        <input id="goalTitle" type="text" class="form-control" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>
    <div class="form-group">
        <label for="targetDate">Target Date (Optional)</label>
        <input id="targetDate" type="date" class="form-control" @bind="newTargetDate" />
    </div>
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
    @if (showValidationMessage)
    {
        <div class="validation-message">Goal title cannot be empty</div>
    }
</div>

<div class="goals-list">
    @if (goals.Cont == 0)
    {
        <p class="no-goals-message"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        @foreach (var goal in goals)
        {
            <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                <div class="goal-content">
                    <div class="goal-header">
                        <span class="goal-title">@goal.Title</span>
                        @if (goal.TargetDate.HasValue)
                        {
                            <span class="goal-date">@goal.TargetDate.Value.ToShortDateString()</span>
                        }
                    </div>
                </div>
                <div class="goal-actions">
                    <button class="btn btn-sm btn-outline-success" @onclick="() => ToggleGoal(goal.Id)">
                        @(goal.IsCompleted ? "Uncomplete" : "Complete")
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newTargetDate;
    private bool showValidationMessage = false;

    private void AddGoal()
    {
        // Validate title
        if (string.IsNullOrWhiteSpace(newGoalTitle))
        {
            showValidationMessage = true;
            return;
        }

        // Create and add new goal
        var goal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = newGoalTitle.Trim(),
            TargetDate = newTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Clear form
        newGoalTitle = string.Empty;
        newTargetDate = null;
        showValidationMessage = false;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    public class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
