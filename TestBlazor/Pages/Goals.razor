@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your goals and mark them as completed when you achieve them.</p>

<div class="goals-form">
    <h3>Add New Goal</h3>
    <div class="form-group">
        <label for="goalTitle">Goal Title:</label>
        <input id="goalTitle" type="text" class="form-control" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>
    <div class="form-group">
        <label for="goalDate">Target Date (optional):</label>
        <input id="goalDate" type="date" class="form-control" @bind="newGoalTargetDate" />
    </div>
    @if (!string.IsNullOrWhiteSpace(validationMessage))
    {
        <div class="alert alert-danger" role="alert">
            @validationMessage
        </div>
    }
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

@if (goals.Count > 0)
{
    <div class="goals-list">
        <h3>Your Goals</h3>
        @foreach (var goal in goals)
        {
            <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                <div class="goal-content">
                    <div class="goal-header">
                        <span class="goal-title">@goal.Title</span>
                        @if (goal.TargetDate.HasValue)
                        {
                            <span class="goal-date">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</span>
                        }
                    </div>
                </div>
                <div class="goal-actions">
                    <button class="btn btn-sm btn-success" @onclick="() => ToggleGoal(goal.Id)">
                        @(goal.IsCompleted ? "Uncomplete" : "Complete")
                    </button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="no-goals">
        <p><em>No goals yet. Add your first goal above!</em></p>
    </div>
}

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate = null;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Trim and validate input
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty. Please enter a valid title.";
            return;
        }

        // Clear validation message
        validationMessage = string.Empty;

        // Add new goal
        var goal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Clear form
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    public class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
