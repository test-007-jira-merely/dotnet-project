@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and mark them complete when achieved.</p>

<div class="goals-form">
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input type="text" class="form-control" id="goalTitle" @bind="newTitle" placeholder="Enter your goal" />
    </div>
    <div class="mb-3">
        <label for="goalDate" class="form-label">Target Date (Optional)</label>
        <input type="date" class="form-control" id="goalDate" @bind="newTargetDate" />
    </div>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-error">
            @validationMessage
        </div>
    }
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list mt-4">
    @if (goals.Count == 0)
    {
        <p class="text-muted"><em>No goals yet. Add your first goal above!</em></p>
    }
    else
    {
        <ul class="list-unstyled">
            @foreach (var goal in goals)
            {
                <li class="goal-item @(goal.IsCompleted ? "goal-completed" : "")">
                    <div class="goal-content">
                        <div class="goal-info">
                            <strong>@goal.Title</strong>
                            @if (goal.TargetDate.HasValue)
                            {
                                <div class="goal-date">
                                    <small class="text-muted">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</small>
                                </div>
                            }
                        </div>
                        <div class="goal-actions">
                            <button class="btn btn-sm btn-outline-success" @onclick="() => ToggleGoal(goal.Id)">
                                @(goal.IsCompleted ? "Undo" : "Complete")
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private List<Goal> goals = new();
    private string newTitle = "";
    private DateTime? newTargetDate = null;
    private string? validationMessage = null;

    private void AddGoal()
    {
        // Clear previous validation message
        validationMessage = null;

        // Trim and validate title
        var trimmedTitle = newTitle?.Trim() ?? "";
        if (string.IsNullOrEmpty(trimmedTitle))
        {
            validationMessage = "Goal title is required.";
            return;
        }

        // Add new goal to the list
        goals.Add(new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newTargetDate,
            IsCompleted = false
        });

        // Clear form inputs
        newTitle = "";
        newTargetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
