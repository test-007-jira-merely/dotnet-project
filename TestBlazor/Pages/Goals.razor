@page "/goals"
@using TestBlazor.Models

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goal-form">
    <h3>Add a New Goal</h3>
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Title</label>
        <input id="goalTitle" type="text" class="form-control" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>
    <div class="mb-3">
        <label for="goalTargetDate" class="form-label">Target Date (Optional)</label>
        <input id="goalTargetDate" type="date" class="form-control" @bind="newGoalTargetDate" aria-label="Select target date for your goal" />
    </div>
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-message mt-2" role="alert">@validationMessage</div>
    }
</div>

<div class="goals-list mt-4">
    <h3>Your Goals</h3>

    @if (goals.Count == 0)
    {
        <p><em>No goals yet. Add one above to get started!</em></p>
    }
    else
    {
        <div class="goal-items">
            @foreach (var goal in goals)
            {
                <div class="goal-item @(goal.IsCompleted ? "goal-completed" : "")">
                    <div class="goal-info">
                        <div class="goal-title">@goal.Title</div>
                        @if (goal.TargetDate.HasValue)
                        {
                            <div class="goal-date">Target: @goal.TargetDate.Value.ToShortDateString()</div>
                        }
                    </div>
                    <div class="goal-actions">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleGoal(goal.Id)">
                            @(goal.IsCompleted ? "Undo" : "Complete")
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(goal.Id)">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        try
        {
            // Clear previous validation message
            validationMessage = string.Empty;

            // Trim and validate title
            var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

            if (string.IsNullOrEmpty(trimmedTitle))
            {
                validationMessage = "Goal title cannot be empty.";
                return;
            }

            // Check for duplicate goals
            if (goals.Any(g => g.Title.Equals(trimmedTitle, StringComparison.OrdinalIgnoreCase)))
            {
                validationMessage = "A goal with this title already exists.";
                return;
            }

            // Create and add new goal
            var newGoal = new Goal
            {
                Id = Guid.NewGuid(),
                Title = trimmedTitle,
                TargetDate = newGoalTargetDate,
                IsCompleted = false
            };

            goals.Add(newGoal);

            // Reset form
            newGoalTitle = string.Empty;
            newGoalTargetDate = null;
        }
        catch (Exception ex)
        {
            validationMessage = $"An error occurred while adding the goal: {ex.Message}";
        }
    }

    private void ToggleGoal(Guid id)
    {
        try
        {
            var goal = GetGoalById(id);
            if (goal != null)
            {
                goal.IsCompleted = !goal.IsCompleted;
            }
        }
        catch (Exception ex)
        {
            validationMessage = $"An error occurred while toggling the goal: {ex.Message}";
        }
    }

    private void DeleteGoal(Guid id)
    {
        try
        {
            var goal = GetGoalById(id);
            if (goal != null)
            {
                goals.Remove(goal);
            }
        }
        catch (Exception ex)
        {
            validationMessage = $"An error occurred while deleting the goal: {ex.Message}";
        }
    }

    private Goal? GetGoalById(Guid id)
    {
        return goals.FirstOrDefault(g => g.Id == id);
    }
}
