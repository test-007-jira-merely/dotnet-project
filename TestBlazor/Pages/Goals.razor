@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and milestones.</p>

<div class="goal-form">
    <h3>Add New Goal</h3>
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input type="text" class="form-control" id="goalTitle" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>
    <div class="mb-3">
        <label for="goalTargetDate" class="form-label">Target Date (Optional)</label>
        <input type="date" class="form-control" id="goalTargetDate" @bind="newGoalTargetDate" />
    </div>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-message">@validationMessage</div>
    }
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

<div class="goals-list">
    <h3>Your Goals</h3>
    @if (goals.Count == 0)
    {
        <p class="text-muted">No goals yet. Add your first goal above!</p>
    }
    else
    {
        <div class="goals-container">
            @foreach (var goal in goals)
            {
                <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                    <div class="goal-content">
                        <div class="goal-title">@goal.Title</div>
                        @if (goal.TargetDate.HasValue)
                        {
                            <div class="goal-date">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</div>
                        }
                    </div>
                    <div class="goal-actions">
                        <button class="btn btn-sm @(goal.IsCompleted ? "btn-secondary" : "btn-success")"
                                @onclick="() => ToggleGoal(goal.Id)">
                            @(goal.IsCompleted ? "Undo" : "Complete")
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Goal> goals = new();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Reset validation message
        validationMessage = string.Empty;

        // Trim and validate title
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title is required.";
            return;
        }

        // Create new goal
        var newGoal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);

        // Reset form
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
