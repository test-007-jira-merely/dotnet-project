@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and mark them as completed when achieved.</p>

<div class="goal-form mb-4">
    <div class="row g-3">
        <div class="col-md-6">
            <label for="goalTitle" class="form-label">Goal Title</label>
            <input id="goalTitle"
                   type="text"
                   class="form-control"
                   @bind="currentTitle"
                   @bind:event="oninput"
                   @onkeyup="OnTitleKeyUp"
                   placeholder="Enter your goal..."
                   aria-label="Goal title" />
        </div>
        <div class="col-md-4">
            <label for="targetDate" class="form-label">Target Date (Optional)</label>
            <input id="targetDate"
                   type="date"
                   class="form-control"
                   @bind="currentTargetDate"
                   aria-label="Target date" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="AddGoal">Add Goal</button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-error mt-2" role="alert">
            @validationMessage
        </div>
    }
</div>

@if (goals.Count == 0)
{
    <div class="empty-state">
        <p><em>No goals yet. Add your first goal above!</em></p>
    </div>
}
else
{
    <div class="goal-list">
        @foreach (var goal in goals)
        {
            <div class="goal-item @(goal.IsCompleted ? "goal-completed" : "")">
                <div class="goal-content">
                    <div class="goal-header">
                        <h5 class="goal-title">@goal.Title</h5>
                        @if (goal.TargetDate.HasValue)
                        {
                            <span class="goal-date badge bg-secondary">
                                Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")
                            </span>
                        }
                    </div>
                </div>
                <div class="goal-actions">
                    <button class="btn btn-sm @(goal.IsCompleted ? "btn-warning" : "btn-success")"
                            @onclick="() => ToggleGoal(goal.Id)"
                            aria-label="@(goal.IsCompleted ? "Mark as incomplete" : "Mark as complete")">
                        @(goal.IsCompleted ? "Undo" : "Complete")
                    </button>
                    <button class="btn btn-sm btn-danger"
                            @onclick="() => DeleteGoal(goal.Id)"
                            aria-label="Delete goal">
                        Delete
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Goal> goals = new();
    private string currentTitle = "";
    private DateTime? currentTargetDate = null;
    private string? validationMessage = null;

    private void AddGoal()
    {
        // Trim and validate the title
        var trimmedTitle = currentTitle?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Create and add the new goal
        var newGoal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = currentTargetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);

        // Clear the form
        currentTitle = "";
        currentTargetDate = null;
        validationMessage = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private void OnTitleKeyUp(KeyboardEventArgs e)
    {
        // Clear validation message when user starts typing
        if (!string.IsNullOrEmpty(validationMessage))
        {
            validationMessage = null;
        }

        // Allow adding goal by pressing Enter
        if (e.Key == "Enter")
        {
            AddGoal();
        }
    }

    public class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
