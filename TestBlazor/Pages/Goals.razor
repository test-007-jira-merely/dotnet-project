@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goals-form">
    <h3>Add New Goal</h3>
    <div class="form-group mb-3">
        <label for="goalTitle">Title:</label>
        <input id="goalTitle" type="text" class="form-control" @bind="newGoalTitle" placeholder="Enter goal title" />
    </div>
    <div class="form-group mb-3">
        <label for="targetDate">Target Date (optional):</label>
        <input id="targetDate" type="date" class="form-control" @bind="newTargetDate" />
    </div>
    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-message">@validationMessage</div>
    }
</div>

<div class="goals-list">
    @if (goals.Count == 0)
    {
        <p class="no-goals-message"><em>No goals yet. Add one above!</em></p>
    }
    else
    {
        <h3>Your Goals</h3>

        @* Active Goals *@
        @if (goals.Any(g => !g.IsCompleted))
        {
            <div class="goals-section">
                <h4>Active</h4>
                @foreach (var goal in goals.Where(g => !g.IsCompleted))
                {
                    <div class="goal-item">
                        <div class="goal-content">
                            <input type="checkbox" @onchange="() => ToggleGoal(goal.Id)" checked="@goal.IsCompleted" />
                            <div class="goal-details">
                                <span class="goal-title">@goal.Title</span>
                                @if (goal.TargetDate.HasValue)
                                {
                                    <span class="goal-date">Target: @goal.TargetDate.Value.ToShortDateString()</span>
                                }
                            </div>
                        </div>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                    </div>
                }
            </div>
        }

        @* Completed Goals *@
        @if (goals.Any(g => g.IsCompleted))
        {
            <div class="goals-section">
                <h4>Completed</h4>
                @foreach (var goal in goals.Where(g => g.IsCompleted))
                {
                    <div class="goal-item completed">
                        <div class="goal-content">
                            <input type="checkbox" @onchange="() => ToggleGoal(goal.Id)" checked="@goal.IsCompleted" />
                            <div class="goal-details">
                                <span class="goal-title">@goal.Title</span>
                                @if (goal.TargetDate.HasValue)
                                {
                                    <span class="goal-date">Target: @goal.TargetDate.Value.ToShortDateString()</span>
                                }
                            </div>
                        </div>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteGoal(goal.Id)">Delete</button>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newTargetDate;
    private string? validationMessage;

    private void AddGoal()
    {
        // Trim and validate title
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Create and add new goal
        var newGoal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newTargetDate,
            IsCompleted = false
        };

        goals.Insert(0, newGoal); // Add to beginning for newest-first display

        // Clear form and validation
        newGoalTitle = string.Empty;
        newTargetDate = null;
        validationMessage = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    // Goal model
    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
