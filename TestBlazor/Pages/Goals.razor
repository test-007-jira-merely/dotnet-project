@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<p>Track your personal goals and mark them as complete when achieved.</p>

<div class="goal-form">
    <div class="mb-3">
        <label for="goalTitle" class="form-label">Goal Title</label>
        <input id="goalTitle"
               class="form-control"
               type="text"
               @bind="newGoalTitle"
               @bind:event="oninput"
               placeholder="Enter a goal..."
               maxlength="200" />
    </div>

    <div class="mb-3">
        <label for="targetDate" class="form-label">Target Date (Optional)</label>
        <input id="targetDate"
               class="form-control"
               type="date"
               @bind="newGoalTargetDate" />
    </div>

    @if (!string.IsNullOrWhiteSpace(validationMessage))
    {
        <div class="validation-message mb-3">@validationMessage</div>
    }

    <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
</div>

@if (goals.Any())
{
    <div class="goals-list mt-4">
        <h3>Your Goals</h3>

        @foreach (var goal in goals.OrderBy(g => g.IsCompleted).ThenBy(g => g.TargetDate))
        {
            <div class="goal-item @(goal.IsCompleted ? "completed" : "")">
                <div class="goal-content">
                    <div class="goal-header">
                        <input type="checkbox"
                               class="form-check-input"
                               checked="@goal.IsCompleted"
                               @onchange="() => ToggleGoal(goal.Id)"
                               id="goal-@goal.Id" />
                        <label class="form-check-label goal-title" for="goal-@goal.Id">
                            @goal.Title
                        </label>
                    </div>
                    @if (goal.TargetDate.HasValue)
                    {
                        <div class="goal-date">
                            <small class="text-muted">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</small>
                        </div>
                    }
                </div>
                <button class="btn btn-sm btn-outline-danger delete-btn"
                        @onclick="() => DeleteGoal(goal.Id)"
                        title="Delete goal">
                    &times;
                </button>
            </div>
        }
    </div>
}
else
{
    <div class="mt-4">
        <p class="text-muted"><em>No goals yet. Add your first goal above!</em></p>
    </div>
}

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate = null;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Reset validation message
        validationMessage = string.Empty;

        // Validate input
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Add new goal
        var goal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(goal);

        // Reset form
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    // Goal model
    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
