@page "/goals"

<PageTitle>Goals</PageTitle>

<h1>Goals</h1>

<div class="goals-container">
    <div class="goal-form">
        <h3>Add a New Goal</h3>
        <div class="mb-3">
            <label for="goalTitle" class="form-label">Goal Title</label>
            <input type="text" class="form-control" id="goalTitle" @bind="newGoalTitle" placeholder="Enter your goal" />
        </div>
        <div class="mb-3">
            <label for="goalTargetDate" class="form-label">Target Date (Optional)</label>
            <input type="date" class="form-control" id="goalTargetDate" @bind="newGoalTargetDate" />
        </div>
        @if (!string.IsNullOrEmpty(validationMessage))
        {
            <div class="validation-error">
                @validationMessage
            </div>
        }
        <button class="btn btn-primary" @onclick="AddGoal">Add Goal</button>
    </div>

    <div class="goals-list">
        <h3>Your Goals</h3>
        @if (goals == null || !goals.Any())
        {
            <p class="no-goals">No goals yet. Add your first goal above!</p>
        }
        else
        {
            <div class="goal-items">
                @foreach (var goal in goals.OrderBy(g => g.IsCompleted).ThenBy(g => g.TargetDate))
                {
                    <div class="goal-item @(goal.IsCompleted ? "completed-goal" : "")">
                        <div class="goal-content">
                            <div class="goal-header">
                                <h5>@goal.Title</h5>
                                @if (goal.TargetDate.HasValue)
                                {
                                    <span class="goal-date">Target: @goal.TargetDate.Value.ToString("MMM dd, yyyy")</span>
                                }
                            </div>
                        </div>
                        <div class="goal-actions">
                            <button class="btn btn-sm btn-outline-success" @onclick="() => ToggleGoal(goal.Id)">
                                @(goal.IsCompleted ? "Undo" : "Complete")
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(goal.Id)">
                                Delete
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Goal> goals = new List<Goal>();
    private string newGoalTitle = string.Empty;
    private DateTime? newGoalTargetDate;
    private string validationMessage = string.Empty;

    private void AddGoal()
    {
        // Trim and validate the title
        var trimmedTitle = newGoalTitle?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            validationMessage = "Goal title cannot be empty.";
            return;
        }

        // Create and add the new goal
        var newGoal = new Goal
        {
            Id = Guid.NewGuid(),
            Title = trimmedTitle,
            TargetDate = newGoalTargetDate,
            IsCompleted = false
        };

        goals.Add(newGoal);

        // Clear the form
        newGoalTitle = string.Empty;
        newGoalTargetDate = null;
        validationMessage = string.Empty;
    }

    private void ToggleGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goal.IsCompleted = !goal.IsCompleted;
        }
    }

    private void DeleteGoal(Guid id)
    {
        var goal = goals.FirstOrDefault(g => g.Id == id);
        if (goal != null)
        {
            goals.Remove(goal);
        }
    }

    private class Goal
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime? TargetDate { get; set; }
        public bool IsCompleted { get; set; }
    }
}
